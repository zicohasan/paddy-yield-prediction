*.adf
*.tif
*.tiff
*.zip

# Environment
.env
.venv
env/
venv/
*.conda

# Jupyter
.ipynb_checkpoints
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini
~$*

